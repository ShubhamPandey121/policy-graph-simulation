# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/
DB_NAME=policy_graph_db

# Cloud LLM API Configuration (Choose ONE of the following setups)

# Option A: Groq API (Super Fast, Generous Free Tier, 128k Token Context for large PDFs)
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_API_KEY=your_api_key_here
MODEL_NAME=llama-3.3-70b-versatile

# Option B: DeepSeek API
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_API_KEY=sk-your_deepseek_api_key_here
# MODEL_NAME=deepseek-chat

# Option C: OpenAI API
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-your_openai_api_key_here
# MODEL_NAME=gpt-4o-mini
